PORT=3000
DB_PATH=./data/db.sqlite

# Recommended for production: set these explicitly. If left blank, the server
# auto-generates and stores them in the same SQLite file as the data they
# protect (encrypted Tidal tokens) — fine for casual homelab use, but anyone
# who obtains db.sqlite gets the key too (AUDIT.md M5).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
SESSION_SECRET=
