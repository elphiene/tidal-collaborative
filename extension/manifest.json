{
  "manifest_version": 3,
  "name": "Tidal Collaborative",
  "version": "0.1.0",
  "description": "Real-time collaborative Tidal playlist sync",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://listen.tidal.com/*",
    "https://api.tidal.com/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://listen.tidal.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tidal Collaborative"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
